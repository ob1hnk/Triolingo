# This .gitignore file should be placed at the root of your Unity project directory
#
# Get latest from https://github.com/github/gitignore/blob/main/Unity.gitignore
#
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]ser[Ss]ettings/

# Unity VCS (Plastic SCM)
.plastic/

# MemoryCaptures can get excessive in size.
# They also could contain extremely sensitive data
/[Mm]emoryCaptures/

# Recordings can get excessive in size
/[Rr]ecordings/

# Uncomment this line if you wish to ignore the asset store tools plugin
# /[Aa]ssets/AssetStoreTools*

# Autogenerated Jetbrains Rider plugin
/[Aa]ssets/Plugins/Editor/JetBrains*

# Visual Studio cache directory
.vs/

# Gradle cache directory
.gradle/

# Autogenerated VS/MD/Consulo solution and project files
ExportedObj/
.consulo/
*.csproj
*.unityproj
*.sln
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Unity3D generated meta files
*.pidb.meta
*.pdb.meta
*.mdb.meta

# Unity3D generated file on crash reports
sysinfo.txt

# Builds
*.apk
*.aab
*.unitypackage
*.unitypackage.meta
*.app

# Crashlytics generated file
crashlytics-build.properties

# Packed Addressables
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*

# Temporary auto-generated Android Assets
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# Assets - 에셋 폴더 내용 무시 (단, .meta와 MyAssets 제외)
/Assets/3DModels/VFX/**
!/Assets/3DModels/VFX/Polygonal Particles/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/Materials/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/Meshes/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/Prefabs/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/Prefabs/Water/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/Shaders/
!/Assets/3DModels/VFX/Polygonal Particles/Assets/**/*.meta

/Assets/3DModels/polyperfect/**
!/Assets/3DModels/polyperfect/**/*.meta

# 만든 파일은 추가
/Assets/3DModels/Forest/**
!/Assets/3DModels/Forest/MyAssets/
!/Assets/3DModels/Forest/MyAssets/**
!/Assets/3DModels/Forest/**/*.meta

/Assets/3DModels/Handpainted_Grass_and_Ground_Textures/**
!/Assets/3DModels/Handpainted_Grass_and_Ground_Textures/**/*.meta

/Assets/3DModels/LowPolyTreePack/**
!/Assets/3DModels/LowPolyTreePack/**/*.meta

/Assets/3DModels/Nature Pack - PBA - URP/**
!/Assets/3DModels/Nature Pack - PBA - URP/**/*.meta

/Assets/3DModels/SimpleLowPolyNature/**
!/Assets/3DModels/SimpleLowPolyNature/**/*.meta

/Assets/3DModels/SimpleNaturePack/**
!/Assets/3DModels/SimpleNaturePack/**/*.meta

# Firebase Unity SDK (각 팀원이 .unitypackage로 직접 설치)
/[Aa]ssets/Firebase/
/[Aa]ssets/Firebase.meta
/[Aa]ssets/ExternalDependencyManager/
/[Aa]ssets/ExternalDependencyManager.meta
/[Aa]ssets/[Ee]ditor Default Resources/Firebase/
/[Aa]ssets/[Ee]ditor Default Resources/Firebase.meta
/[Aa]ssets/[Ee]ditor Default Resources.meta
/[Aa]ssets/[Pp]lugins/iOS/Firebase/
/[Aa]ssets/[Pp]lugins/iOS/Firebase.meta
/[Aa]ssets/[Pp]lugins/tvOS/Firebase/
/[Aa]ssets/[Pp]lugins/tvOS/Firebase.meta
/[Aa]ssets/[Pp]lugins/iOS.meta
/[Aa]ssets/[Pp]lugins/tvOS.meta
/[Aa]ssets/[Pp]lugins.meta
/[Aa]ssets/[Pp]lugins/Android/Firebase*
/[Aa]ssets/[Pp]lugins/Android/res/
/[Aa]ssets/[Ss]treamingAssets/
/[Aa]ssets/[Ss]treamingAssets.meta

# Exclude firebase key
/[Aa]ssets/google-services.json
/[Aa]ssets/google-services.json.meta

# Exclude test scripts
Assets/Scripts/Runtime/Multimodal/Examples/
Assets/Scripts/Runtime/Multimodal/Examples.meta

# FarlandSkies (무료 스카이박스 에셋 - 각 팀원이 직접 설치)
/Assets/FarlandSkies/**
!/Assets/FarlandSkies/**/*.meta

# Floor Textures (에셋 스토어 - 각 팀원이 직접 설치)
/Assets/Scenes/Room/FloorTextures/
/Assets/Scenes/Room/M_YFFlM_11.mat
/Assets/Scenes/Room/T_YFFlM_*.tga